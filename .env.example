# ENSA Project Manager — environment variables
# Copy this file to ".env" and fill in real values. The .env file is gitignored.
# Anything left unset falls back to development-friendly defaults in settings.py.

# --- Core ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# Set to False in production.
DJANGO_DEBUG=True
# Comma-separated list of hostnames the site can serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# Comma-separated HTTPS origins trusted for POST requests (production).
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Database (optional) ---
# Leave DB_ENGINE unset to use the default local SQLite database.
# For PostgreSQL in production:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ensa_project_manager
# DB_USER=ensa
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=5432

# --- Email (optional) ---
# Leave EMAIL_BACKEND unset to print emails to the console in development.
# For real email in production:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@ensaprojectmanager.com

# --- HTTPS / security (production, optional overrides) ---
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_HSTS_SECONDS=31536000
